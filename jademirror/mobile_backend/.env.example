# Flutter 手机 App 专用后端配置（与 jademirror/backend/.env 分离）
# 启动: 复制本文件为同目录 .env 后，在 jademirror/backend 执行  python app_mobile.py
PORT=5001

# 与 Web 可共用同一套 Key，但 .env 文件分开维护
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# 手机填写的公网/局域网 API 根地址提示（可选）
PUBLIC_API_BASE=

# App 端 CORS 在代码中已放宽为 *；一般无需再配
ALLOWED_ORIGINS=*

AUTH_REQUIRED=0
AUTH_TOKEN_TTL_HOURS=168
AUTH_DB_PATH=

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ALLOW_MOCK=0

QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_MODEL=qwen-image-2.0

REQUEST_TIMEOUT=45
REQUEST_MAX_RETRIES=2
RATE_LIMIT_PER_MINUTE=40
