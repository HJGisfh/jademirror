# Web 前端（Vite）使用的后端：python app.py；手机 App 请用仓库 app/backend 单独进程
PORT=5000
# 浏览器场景一般不必填；仅调试时如需对外提示完整 URL
PUBLIC_API_BASE=

# 必须与前端来源一致（逗号分隔）；默认含本地 Vite
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_REQUIRED=0
AUTH_TOKEN_TTL_HOURS=168
AUTH_DB_PATH=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ALLOW_MOCK=0

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_MODEL=qwen-image-2.0

REQUEST_TIMEOUT=45
REQUEST_MAX_RETRIES=2
RATE_LIMIT_PER_MINUTE=40

HUNYUAN3D_API_URL=
HUNYUAN3D_ENABLE_TEXTURE=0
HUNYUAN3D_OCTREE_RESOLUTION=128
HUNYUAN3D_INFERENCE_STEPS=5

ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_ID=doubao-seed3d-2-0-260328

TC_3D_API_KEY=
TC_3D_BASE_URL=https://api.ai3d.cloud.tencent.com

REPLICATE_API_TOKEN=
REPLICATE_MODEL_VERSION=b1b9449a1277e10402781c5d41eb30c0a0683504fb23fab591ca9dfc2aabe1cb

MESHY_API_KEY=
MESHY_BASE_URL=https://api.meshy.ai
