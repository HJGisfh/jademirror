# 复制为 deploy/.env 后填写；勿提交含 Key 的 .env
PORT=5000

# 公网访问地址（用于 /api/health 里 suggested_api_base；填你的服务器 IP 或域名）
PUBLIC_API_BASE=http://150.109.235.111:5000

# 浏览器 / 手机 App 跨域；云上可先用 *，有固定前端域名后再收紧
ALLOWED_ORIGINS=*

DEEPSEEK_API_KEY=
QWEN_API_KEY=

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ALLOW_MOCK=0

QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_MODEL=qwen-image-2.0

AUTH_REQUIRED=0
AUTH_TOKEN_TTL_HOURS=168

REQUEST_TIMEOUT=120
REQUEST_MAX_RETRIES=2
RATE_LIMIT_PER_MINUTE=60
